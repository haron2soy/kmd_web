FROM python:3.11

# System deps
RUN apt-get update && apt-get install -y \
    build-essential libpq-dev curl && rm -rf /var/lib/apt/lists/*

# Set workdir
WORKDIR /app

# Copy requirements first for caching
COPY ../../requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy Django project
COPY ../../forecasts ./forecasts
COPY ../../nwp_models ./nwp_models
COPY ../../products ./products
COPY ../../users ./users
COPY ../../user_account ./user_accounts
COPY ../../pages ./pages
COPY ../../swfp_evaluation ./swfp_evaluation
COPY ../../news ./news
COPY ../../national_met_services ./national_met_services
COPY ../../wrfapi ./wrfapi
COPY ../../home ./home

# Collect static files
RUN python web_service/manage.py collectstatic --noinput

# Expose port for Gunicorn
EXPOSE 8000

# Run Gunicorn
CMD ["gunicorn", "rsmc_config.config.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]
